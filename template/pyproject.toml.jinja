[build-system]
# Build backend for the project
# Keeping a build step in CI is useful as a validation check even though this
# template is primarily designed for checked-out repo usage

requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
# Package name, currently a placeholder
name = "{{ project_slug }}"

# Don't also define __version__ in __init__.py — importlib.metadata reads
# this value at runtime. One place to change it = zero drift
version = "0.1.0"

description = "{{ project_description }}"
readme = "README.md"

# Minimum supported Python version for the project
# Ruff and ty can infer the project Python version from here
requires-python = ">={{ python_min_version }}"

authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]

license = { file = "LICENSE" }

# settings.py uses pydantic-settings for typed, auditable runtime configuration
# This handles .env loading, environment variable overrides, and type coercion
dependencies = ["pydantic-settings"]

[dependency-groups]
# Dev-only tools: linting, typing, tests, coverage, hooks
# uv treats the "dev" group specially and syncs it by default
dev = [
    "ruff",
    "mypy",
    # ty is Astral's next-generation type checker — faster than mypy but pre-1.0
    # as of early 2026, meaning it can produce false positives on complex
    # library types that mypy handles reliably
    # To try it: uv add --dev ty, then run: uv run ty check
    # Switch it in here when ty reaches stable and you have verified it handles
    # your codebase cleanly — track releases at https://github.com/astral-sh/ty
    # "ty",
    "pytest",
    "pytest-cov",
    "pre-commit",
]

[tool.uv]
# Make default group behavior obvious
# plain "uv sync" installs the base project + dev tools
# Other groups stay opt-in so the starter doesn't become bloated by default
# i.e. you'll need to explicitly tell uv to install them...
default-groups = ["dev"]

[tool.hatch.build.targets.wheel]
# Keep src imports honest and let CI catch packaging drift
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
# Require a modern pytest
minversion = "8.0"

# Keep tests at the repo root instead of mixing them into src/
testpaths = ["tests"]

# Good defaults for CI and local runs:
# -ra: show extra summary info
# --strict-config: fail on bad pytest config
# --strict-markers: fail on unknown markers instead of silently accepting typos
# --cov: measure coverage for the package, not random files
# --cov-report=term-missing:skip-covered: useful signal without too much noise
addopts = [
    "-ra",
    "--strict-config",
    "--strict-markers",
    "--cov={{ package_name }}",
    "--cov-report=term-missing:skip-covered",
]

# If an expected-fail test suddenly passes, show it
xfail_strict = true

[tool.coverage.run]
# Branch coverage is more useful than line-only coverage
branch = true

# Only measure your package, not tests or tooling code.
source = ["{{ package_name }}"]

[tool.coverage.report]
show_missing = true
skip_covered = true

# Common exclusions that usually aren't worth counting
# coverage.py documents exclude_also for adding custom exclusions like these
exclude_also = [
    "pragma: no cover",
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
    "raise AssertionError",
]

[tool.ruff]
# 100 is a practical line length for application code, chain-heavy code, and docstrings
line-length = 100

# Tell Ruff that src/ is the package root for import classification
src = ["src"]

# Pin Ruff's behaviour to the project's chosen Python version so formatting
# is identical regardless of which Python interpreter is actually running.
target-version = "py{{ python_min_version | replace('.', '') }}"

[tool.ruff.lint]
# Keep preview off in a template unless you intentionally want unstable rules/fixes
preview = false

# Explicit rule selection is easier to control than ALL
# This set provides a strong default without making life a total misery
select = [
    "E4",   # pycodestyle import / syntax-related errors
    "E7",
    "E9",
    "F",    # pyflakes correctness checks
    "I",    # import sorting
    "UP",   # pyupgrade
    "B",    # bugbear
    "SIM",  # simplifications
    "C4",   # comprehensions
    "PIE",  # small correctness / cleanup wins
    "RUF",  # Ruff-native rules
    # ANN enforces type annotations on all function arguments and return values
    # in src/ — this is intentionally strict and reflects the template's view
    # that reusable code benefits from explicit types for readability and for
    # catching subtle bugs (wrong return type, unexpected None, etc)
    #
    # If this feels too aggressive for your project's current stage, you can
    # relax it in two ways:
    #
    # Option 1 — disable ANN entirely by removing it from this list
    #
    # Option 2 — keep it but ignore specific rules that are causing noise:
    #   "ANN001"  missing argument annotation
    #   "ANN201"  missing return type on public function
    #   "ANN202"  missing return type on private function
    #
    # Add whichever you want to the ignore list below
    "ANN",  # type annotation coverage
]

ignore = [
    "ANN401", # don't force removal of Any everywhere
    "PD008",  # allow .at
    "PD009",  # allow .iat
]

[tool.ruff.lint.per-file-ignores]
# Tests can be less strict about annotations
"tests/**/*.py" = ["ANN"]

# Re-exports in __init__.py are normal
"__init__.py" = ["F401"]

[tool.ruff.lint.flake8-annotations]
# Actually enforce annotation coverage
ignore-fully-untyped = false

[tool.ruff.lint.isort]
# Tell ruff which package is this project's own code
# Without this, ruff may classify it as third-party and sort imports incorrectly
known-first-party = ["{{ package_name }}"]

[tool.ruff.format]
# Stay on stable formatter behavior
preview = false

# Also format Python code in docstrings
docstring-code-format = true

# type checking

# ty — Astral's next-generation type checker (not active in this project).
# This config stub is ready to use if you enable ty in the dev dependency
# group above. Until then, mypy is the primary type checker.
# If your editor auto-detects this section and shows ty warnings, you can
# safely ignore them or disable the ty extension until you opt in.

[tool.ty.src]
include = ["src", "tests"]

[tool.ty.terminal]
output-format = "concise"

#mypy

# mypy is the primary type checker for this project
# It is run in CI and can be run locally with: uv run mypy src tests
#
# strict mode is intentionally off — it requires annotations everywhere
# including on third-party code, which is too aggressive for many projects
# The settings below give you reliable, trustworthy errors without that overhead
[tool.mypy]
python_version = "{{ python_min_version }}"

# Warn when a function returns Any without explicitly annotating it as such
warn_return_any = true

# Warn about mypy config options that have no effect
warn_unused_configs = true

# Warn when code is unreachable due to type narrowing
warn_unreachable = true

# Don't crash on missing stubs for third-party libraries.
# This keeps mypy usable without requiring stub packages for every dependency.
ignore_missing_imports = true

# Check the bodies of functions that have no annotations
# Without this, unannotated functions are silently skipped
check_untyped_defs = true

# Disallow calling untyped functions from typed ones
disallow_untyped_calls = false

