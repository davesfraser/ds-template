# Python bytecode and cache folders
# These are auto-generated and should not be committed
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
# Local machine setup only
.venv/
venv/

# Tool caches and local test artifacts
# Safe to delete, should stay out of git
.pytest_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.ty/
.mypy_cache/

# Editor-specific folders
# Personal workspace settings, not project source
.vscode/.ropeproject
.idea/

# OS-generated junk files
.DS_Store
Thumbs.db

# Environment files
# Often contain secrets or machine-specific config
.env
.env.*
!.env.example

# Data files — binary/large data should not be in version control
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Model artefacts and generated figures
models/*
!models/.gitkeep
reports/figures/*
!reports/figures/.gitkeep
!reports/figures/README.md
