{
  // Pylance is the language server — it handles autocomplete, hover docs,
  // go-to-definition and import resolution
  // It is NOT doing type checking here — mypy owns that job
  "python.languageServer": "Pylance",

  // Turning this off stops Pylance producing its own type squiggles
  // Without this, you get errors from both Pylance and mypy simultaneously
  // and there is no way to tell which tool flagged which error
  "python.analysis.typeCheckingMode": "off",

  // Analyse the full workspace so autocomplete works across all project files,
  // not just whichever file is currently open
  "python.analysis.diagnosticMode": "workspace",

  // Ruff handles all Python formatting and import sorting on save
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },

  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Use pytest, not unittest
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],

  // Activate the project virtual environment automatically in the terminal
  "python.terminal.activateEnvironment": true
}
