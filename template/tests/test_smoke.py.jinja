from {{ package_name }} import __version__
from {{ package_name }}.paths import (
    DATA_DIR,
    DATA_EXTERNAL,
    DATA_INTERIM,
    DATA_PROCESSED,
    DATA_RAW,
    FIGURES_DIR,
    MODELS_DIR,
    NOTEBOOKS_DIR,
    project_root,
)
from {{ package_name }}.settings import settings


def test_version_resolves() -> None:
    assert isinstance(__version__, str)
    assert __version__ != "0.0.0+unknown"


def test_project_root_exists() -> None:
    assert project_root().is_dir()


def test_settings_loads() -> None:
    assert settings.environment == "development"


# project-template:extension:smoke-tests:start
def test_data_science_settings_load() -> None:
    assert isinstance(settings.alpha, float)
    assert isinstance(settings.min_sample_size, int)
    assert isinstance(settings.random_seed, int)


def test_data_science_path_constants_exist() -> None:
    root = project_root()
    constants = [
        DATA_DIR,
        DATA_EXTERNAL,
        DATA_INTERIM,
        DATA_PROCESSED,
        DATA_RAW,
        FIGURES_DIR,
        MODELS_DIR,
        NOTEBOOKS_DIR,
    ]

    for path in constants:
        assert path.is_relative_to(root)
        assert path.exists()


